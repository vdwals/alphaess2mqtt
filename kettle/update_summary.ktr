    <compare>
      <condition>
        <negated>N</negated>
        <conditions>
          <condition>
            <negated>N</negated>
            <leftvalue>last_retrieved</leftvalue>
            <function>IS NULL</function>
            <rightvalue/>
          </condition>
          <condition>
