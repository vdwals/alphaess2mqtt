  <step>
    <name>Load job</name>
    <type>TableInput</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>HA-Database-Kettle</connection>
    <sql>SELECT  td.full_date,
        td.date_key,
        td.full_date = CURDATE() AS today_flag,
        aelj.url,
        aelj.interval_s,
        aelj.last_retrieved,
        aelj.last_requested,
        aelj.next_request,
        aeb.sn,
        aesd.battery_sn, 
        TIMESTAMPDIFF(SECOND, td.full_date, NOW()) &lt;= 2 * aelj.interval_s AS update_yesterday_flag,
		NOW() AS now
    FROM    Time_Dimension td
        LEFT JOIN   alpha_ess_load_jobs aelj 
            ON  LOWER(aelj.url) LIKE '%summery%'
        LEFT JOIN   alpha_ess_batteries aeb
            ON  1=1
        LEFT JOIN   alpha_ess_summary_data aesd
            ON  aeb.sn = aesd.battery_sn 
            AND aesd.`date` = td.date_key 
    WHERE   td.full_date BETWEEN CURDATE() - 1 AND CURDATE()</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
