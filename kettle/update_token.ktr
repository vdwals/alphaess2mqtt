    <sql>SELECT  a.*,
        CONCAT(
            '{',
            GROUP_CONCAT(
                CONCAT(
                    '"',
                    b.name,
                    '": "',
                    b.value,
                    '"')
                ),
            '}'
            ) as body
    FROM    alpha_ess_load_jobs a,
            alpha_ess_settings b
    WHERE   LOWER(url) LIKE '%login%'</sql>
